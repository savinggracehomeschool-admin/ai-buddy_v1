# Copy this to .env and fill in real values. Never commit .env.

# ── Canvas REST API ──────────────────────────────────────────────────────────
CANVAS_BASE_URL=https://your-school.instructure.com
CANVAS_API_TOKEN=replace-with-sgeg-assistant-token
ANTHROPIC_API_KEY=replace-with-anthropic-key

# ── Admin dashboard basic auth ────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-immediately

# ── Canvas user IDs for internal messaging ────────────────────────────────────
# Find your user id at https://<canvas>/users/<NNNN>.
ADMIN_CANVAS_USER_ID=
CURRICULUM_TEAM_CANVAS_USER_ID=

# ── LTI 1.3 ──────────────────────────────────────────────────────────────────
# Client ID assigned by Canvas when you create an LTI Developer Key.
LTI_CLIENT_ID=
# Deployment ID from the Canvas LTI deployment (Settings → Apps → deployment).
LTI_DEPLOYMENT_ID=
# Secret used to sign session cookies. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LTI_SECRET_KEY=change-this-to-a-random-64-char-string
# Set to true to enable /lti/dev mock-launch endpoint (local development only).
LTI_DEV_MODE=true

# --- SGEG Help Desk connection (open tickets from AI-buddy escalations) ---
# The SGEG connector "create ticket" endpoint + the connector Bearer key.
TICKET_API_URL=https://www.savinggraceeducation.co.za/wp-json/sgeg/v1/tickets
TICKET_API_KEY=your-sgeg-connector-key
